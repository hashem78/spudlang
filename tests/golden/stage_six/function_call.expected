FUNCTION_CALL foo ( )
  EXPRESSION foo
FUNCTION_CALL bar ( 1 )
  EXPRESSION bar
  NUMERIC_LITERAL 1
FUNCTION_CALL greet ( "world" )
  EXPRESSION greet
  STRING_LITERAL "world"
FUNCTION_CALL add ( 1 , 2 )
  EXPRESSION add
  NUMERIC_LITERAL 1
  NUMERIC_LITERAL 2
FUNCTION_CALL foo ( bar ( 1 ) )
  EXPRESSION foo
  FUNCTION_CALL bar ( 1 )
    EXPRESSION bar
    NUMERIC_LITERAL 1