ASSIGNMENT f := ( x ) =>
  EXPRESSION f
  FUNCTION_DEF ( x ) =>
    BINARY_OP x + 1
      EXPRESSION x
      NUMERIC_LITERAL 1
ASSIGNMENT add := ( a , b ) =>
  EXPRESSION add
  FUNCTION_DEF ( a , b ) =>
    ASSIGNMENT result := a + b
      EXPRESSION result
      BINARY_OP a + b
        EXPRESSION a
        EXPRESSION b
    EXPRESSION result